<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zov.smart.nova.infra.audit.mapper.AuditOperationLogMapper">

    <resultMap id="AuditOperationLogResultMap" type="com.zov.smart.nova.infra.audit.entity.AuditOperationLogDO">
        <id column="id" property="id"/>
        <result column="trace_id" property="traceId"/>
        <result column="operation_name" property="operationName"/>
        <result column="operation_type" property="operationType" typeHandler="com.zov.smart.nova.common.mybatis.handler.EnumCodeTypeHandler"/>
        <result column="request_method" property="requestMethod"/>
        <result column="request_uri" property="requestUri"/>
        <result column="request_params" property="requestParams"/>
        <result column="response_body" property="responseBody"/>
        <result column="success_flag" property="successFlag"/>
        <result column="error_message" property="errorMessage"/>
        <result column="operator_id" property="operatorId"/>
        <result column="operator_name" property="operatorName"/>
        <result column="client_ip" property="clientIp"/>
        <result column="user_agent" property="userAgent"/>
        <result column="cost_time_ms" property="costTimeMs"/>
        <result column="created_at" property="createdAt"/>
        <result column="delete_flag" property="deleteFlag"/>
        <result column="version" property="version"/>
    </resultMap>

    <sql id="BaseColumns">
        id,
        trace_id,
        operation_name,
        operation_type,
        request_method,
        request_uri,
        request_params,
        response_body,
        success_flag,
        error_message,
        operator_id,
        operator_name,
        client_ip,
        user_agent,
        cost_time_ms,
        created_at,
        delete_flag,
        version
    </sql>

    <select id="selectOneById" resultMap="AuditOperationLogResultMap">
        SELECT
        <include refid="BaseColumns"/>
        FROM audit_operation_log
        WHERE id = #{id}
          AND delete_flag = 0
        LIMIT 1
    </select>

    <select id="selectPageByCriteria" resultMap="AuditOperationLogResultMap">
        SELECT
        <include refid="BaseColumns"/>
        FROM audit_operation_log
        WHERE delete_flag = 0
        <if test="criteria != null and criteria.traceId != null and criteria.traceId != ''">
            AND trace_id = #{criteria.traceId}
        </if>
        <if test="criteria != null and criteria.operationName != null and criteria.operationName != ''">
            AND operation_name LIKE CONCAT('%', #{criteria.operationName}, '%')
        </if>
        <if test="criteria != null and criteria.operationType != null">
            AND operation_type = #{criteria.operationType.code}
        </if>
        <if test="criteria != null and criteria.successFlag != null">
            AND success_flag = #{criteria.successFlag}
        </if>
        <if test="criteria != null and criteria.operatorId != null">
            AND operator_id = #{criteria.operatorId}
        </if>
        <if test="criteria != null and criteria.startTime != null">
            AND created_at &gt;= #{criteria.startTime}
        </if>
        <if test="criteria != null and criteria.endTime != null">
            AND created_at &lt;= #{criteria.endTime}
        </if>
        ORDER BY created_at DESC, id DESC
    </select>
</mapper>
