<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zov.smart.nova.data.access.system.mapper.SysConfigMapper">
    <resultMap id="SysConfigResultMap" type="com.zov.smart.nova.data.access.system.entity.SysConfigDO">
        <id column="id" property="id"/>
        <result column="config_key" property="configKey"/>
        <result column="config_value" property="configValue"/>
        <result column="config_name" property="configName"/>
        <result column="config_type" property="configType" typeHandler="com.zov.smart.nova.common.mybatis.handler.EnumCodeTypeHandler"/>
        <result column="remark" property="remark"/>
        <result column="created_by" property="createdBy"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_by" property="updatedBy"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="delete_flag" property="deleteFlag"/>
        <result column="version" property="version"/>
    </resultMap>

    <sql id="BaseColumnList">
        id, config_key, config_value, config_name, config_type, remark,
        created_by, created_at, updated_by, updated_at, delete_flag, version
    </sql>

    <select id="selectByConfigKey" resultMap="SysConfigResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM sys_config
        WHERE config_key = #{configKey}
          AND delete_flag = 0
        LIMIT 1
    </select>

    <select id="selectConfigPage" resultMap="SysConfigResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM sys_config
        WHERE delete_flag = 0
        <if test="configKey != null and configKey != ''">
            AND config_key LIKE CONCAT('%', #{configKey}, '%')
        </if>
        <if test="configName != null and configName != ''">
            AND config_name LIKE CONCAT('%', #{configName}, '%')
        </if>
        <if test="configType != null and configType != ''">
            AND config_type = #{configType}
        </if>
        ORDER BY id DESC
    </select>
</mapper>
