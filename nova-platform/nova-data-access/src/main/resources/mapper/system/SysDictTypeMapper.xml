<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zov.smart.nova.data.access.system.mapper.SysDictTypeMapper">
    <resultMap id="SysDictTypeResultMap" type="com.zov.smart.nova.data.access.system.entity.SysDictTypeDO">
        <id column="id" property="id"/>
        <result column="dict_code" property="dictCode"/>
        <result column="dict_name" property="dictName"/>
        <result column="status" property="status" typeHandler="com.zov.smart.nova.common.mybatis.handler.EnumCodeTypeHandler"/>
        <result column="remark" property="remark"/>
        <result column="created_by" property="createdBy"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_by" property="updatedBy"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="delete_flag" property="deleteFlag"/>
        <result column="version" property="version"/>
    </resultMap>

    <sql id="BaseColumnList">
        id, dict_code, dict_name, status, remark,
        created_by, created_at, updated_by, updated_at, delete_flag, version
    </sql>

    <select id="selectByDictCode" resultMap="SysDictTypeResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM sys_dict_type
        WHERE dict_code = #{dictCode}
          AND delete_flag = 0
        LIMIT 1
    </select>

    <select id="selectDictTypePage" resultMap="SysDictTypeResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM sys_dict_type
        WHERE delete_flag = 0
        <if test="dictCode != null and dictCode != ''">
            AND dict_code LIKE CONCAT('%', #{dictCode}, '%')
        </if>
        <if test="dictName != null and dictName != ''">
            AND dict_name LIKE CONCAT('%', #{dictName}, '%')
        </if>
        <if test="status != null and status != ''">
            AND status = #{status}
        </if>
        ORDER BY id DESC
    </select>
</mapper>
