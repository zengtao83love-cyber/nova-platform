<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zov.smart.nova.data.access.system.mapper.SysRoleMapper">
    <resultMap id="SysRoleResultMap" type="com.zov.smart.nova.data.access.system.entity.SysRoleDO">
        <id column="id" property="id"/>
        <result column="role_code" property="roleCode"/>
        <result column="role_name" property="roleName"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="status" property="status" typeHandler="com.zov.smart.nova.common.mybatis.handler.EnumCodeTypeHandler"/>
        <result column="remark" property="remark"/>
        <result column="created_by" property="createdBy"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_by" property="updatedBy"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="delete_flag" property="deleteFlag"/>
        <result column="version" property="version"/>
    </resultMap>

    <sql id="BaseColumnList">
        r.id, r.role_code, r.role_name, r.sort_order, r.status, r.remark,
        r.created_by, r.created_at, r.updated_by, r.updated_at, r.delete_flag, r.version
    </sql>

    <select id="selectRolesByUserId" resultMap="SysRoleResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM sys_role r
        INNER JOIN sys_user_role ur ON ur.role_id = r.id
        WHERE ur.user_id = #{userId}
          AND r.delete_flag = 0
        ORDER BY r.sort_order ASC, r.id ASC
    </select>

    <select id="selectEnabledRolesByUserId" resultMap="SysRoleResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM sys_role r
        INNER JOIN sys_user_role ur ON ur.role_id = r.id
        WHERE ur.user_id = #{userId}
          AND r.delete_flag = 0
          AND r.status = 'ENABLED'
        ORDER BY r.sort_order ASC, r.id ASC
    </select>

    <select id="selectRolePage" resultMap="SysRoleResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM sys_role r
        WHERE r.delete_flag = 0
        <if test="roleCode != null and roleCode != ''">
            AND r.role_code LIKE CONCAT('%', #{roleCode}, '%')
        </if>
        <if test="roleName != null and roleName != ''">
            AND r.role_name LIKE CONCAT('%', #{roleName}, '%')
        </if>
        <if test="status != null and status != ''">
            AND r.status = #{status}
        </if>
        ORDER BY r.sort_order ASC, r.id DESC
    </select>
</mapper>
